# Public site URL — same origin where /images/* is already live (Stripe image scripts build https://ORIGIN/images/...)
# Bare hostname ok (e.g. smashcones.com) — code prepends https:// for metadata and links.
NEXT_PUBLIC_SITE_URL=https://smashcones.com
# Optional: image origin for stripe:images* only if it differs from NEXT_PUBLIC_SITE_URL
# STRIPE_IMAGE_SITE_URL=https://smashcones.com

# Measurement (choose ONE primary path — same idea as SkynPatch/Somavea-style stacks)
#
# A) Direct GA4 (default): gtag.js + SPA page_view + ecommerce events + web vitals + generate_lead
# B) Google Tag Manager: load GTM only; add GA4 (and Ads/Pixel) inside the GTM container. Events push to
#    dataLayer (`page_view`, `begin_checkout`, ecommerce keys). Do not also set GA_MEASUREMENT_ID or
#    you double-count unless you know how to dedupe.
#
# Vercel: set the vars you use on Production + Preview, then redeploy — NEXT_PUBLIC_* is build-inlined.
#
# --- Direct GA4 ---
# Verify: GA4 → Admin → Data streams → Web → Measurement ID; Reports → Realtime.
# Optional: NEXT_PUBLIC_GA_DEBUG=1 → GA4 DebugView + debug_mode on hits (remove after testing).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-LPNJ7WF9LH
# NEXT_PUBLIC_GA_DEBUG=0
#
# --- OR GTM (leave GA_MEASUREMENT_ID unset if GA4 is only inside GTM) ---
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Platform secret key (your smat / hub account). Never commit real values.
STRIPE_SECRET_KEY=sk_test_...
# Webhook: include checkout.session.completed + checkout.session.expired (abandoned checkout email)
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: second Stripe webhook destination (e.g. https://smashcones.com/api/webhooks/stripe/thin)
STRIPE_WEBHOOK_SECRET_THIN=whsec_...

# Stripe Connect — Smash Wraps storefront account (API calls use Stripe-Account).
# When set, Products/Prices below must exist on THIS account (Dashboard: switch to connected account).
STRIPE_CONNECT_ACCOUNT_ID=acct_1THIPiIokkmXI2SV

# Stripe Product + Price IDs — one pair per SKU (create under the same account as Connect, or platform if Connect unset).
# Checkout requires BOTH: the Price must belong to that Product (server verifies; no client-sent amounts).
# Match storefront: 1g = $4.75, 2g = $5.00 per single box (3-pack).
# Generate via API: npm run stripe:seed (requires STRIPE_SECRET_KEY; uses Connect when set)
STRIPE_PRODUCT_ICED_WATERMELON_1G=prod_UFqqg339iOZVkc
STRIPE_PRODUCT_ICED_WATERMELON_2G=prod_UFqqqoBzf3NW1K
STRIPE_PRODUCT_PASSION_FRUIT_1G=prod_UFqqCxjrNimpsz
STRIPE_PRODUCT_PASSION_FRUIT_2G=prod_UFqqurdkdJDqyR
STRIPE_PRODUCT_PINEAPPLE_1G=prod_UFqqwUA1HvO4hA
STRIPE_PRODUCT_PINEAPPLE_2G=prod_UFqqZOcDlKvaBU
STRIPE_PRODUCT_VANILLA_1G=prod_UFqqAejGyxtgDB
STRIPE_PRODUCT_VANILLA_2G=prod_UFqqWHOL0M0lpg
STRIPE_PRICE_ICED_WATERMELON_1G=price_1THL97IokkmXI2SVdhb0Gsxf
STRIPE_PRICE_ICED_WATERMELON_2G=price_1THL98IokkmXI2SV8MEl5Qs3
STRIPE_PRICE_PASSION_FRUIT_1G=price_1THL98IokkmXI2SVx94STkTk
STRIPE_PRICE_PASSION_FRUIT_2G=price_1THL98IokkmXI2SVV3OIJKA4
STRIPE_PRICE_PINEAPPLE_1G=price_1THL99IokkmXI2SVMqZ4p3XT
STRIPE_PRICE_PINEAPPLE_2G=price_1THL99IokkmXI2SVbyWkSBlz
STRIPE_PRICE_VANILLA_1G=price_1THL9AIokkmXI2SVhn1IeRXG
STRIPE_PRICE_VANILLA_2G=price_1THL9AIokkmXI2SVyrl4CedO

# Wholesale (/wholesale) — Product metadata.smashwraps_slug = wholesale-{flavor}-{1g|2g} (matches checkout).
# Greenfield: npm run stripe:seed:wholesale then npm run stripe:print-env:wholesale. Optional: npm run stripe:images:wholesale
# One Product + Price per master case (8× three-packs; $19 / $20 WS). Not in sitemap; noindex.
STRIPE_WHOLESALE_PRODUCT_ICED_WATERMELON_1G=prod_UFrdnVUvmSBA06
STRIPE_WHOLESALE_PRODUCT_ICED_WATERMELON_2G=prod_UFrd7InNYN4d2G
STRIPE_WHOLESALE_PRODUCT_PASSION_FRUIT_1G=prod_UFrd9gDDC890Wf
STRIPE_WHOLESALE_PRODUCT_PASSION_FRUIT_2G=prod_UFrdh55MBg6Rc0
STRIPE_WHOLESALE_PRODUCT_PINEAPPLE_1G=prod_UFrdYmRFy2fJgx
STRIPE_WHOLESALE_PRODUCT_PINEAPPLE_2G=prod_UFrdPF3YSYYIre
STRIPE_WHOLESALE_PRODUCT_VANILLA_1G=prod_UFrdI21Ja3Ux1E
STRIPE_WHOLESALE_PRODUCT_VANILLA_2G=prod_UFrd0sPdFCMzVl
STRIPE_WHOLESALE_PRICE_ICED_WATERMELON_1G=price_1THLuVIokkmXI2SVWih0aLZF
STRIPE_WHOLESALE_PRICE_ICED_WATERMELON_2G=price_1THLuWIokkmXI2SV5EACjhot
# Paste from Dashboard or: npm run stripe:print-env:wholesale (needs STRIPE_SECRET_KEY). Must be 1900¢ USD one-time.
STRIPE_WHOLESALE_PRICE_PASSION_FRUIT_1G=price_1THLuWIokkmXI2SVVTyJE3wi_
STRIPE_WHOLESALE_PRICE_PASSION_FRUIT_2G=price_1THLuXIokkmXI2SVHd4R3PXS
STRIPE_WHOLESALE_PRICE_PINEAPPLE_1G=price_1THLuXIokkmXI2SVK3F6HVKq
STRIPE_WHOLESALE_PRICE_PINEAPPLE_2G=price_1THLuYIokkmXI2SVmUuDy9TO
STRIPE_WHOLESALE_PRICE_VANILLA_1G=price_1THLuYIokkmXI2SVkZOgTjPo
STRIPE_WHOLESALE_PRICE_VANILLA_2G=price_1THLuZIokkmXI2SVGm8tDCWK

# Optional: internal copy of wholesale inquiry form (POST /api/email/wholesale-inquiry)
# WHOLESALE_INQUIRY_TO_EMAIL=ops@yourdomain.com

# Optional: Organization JSON-LD (E-E-A-T) — sameAs = comma- or newline-separated profile URLs
# NEXT_PUBLIC_ORG_SAME_AS=https://instagram.com/yourbrand,https://www.youtube.com/@yourbrand
# NEXT_PUBLIC_ORG_CONTACT_EMAIL=support@example.com
# NEXT_PUBLIC_ORG_CONTACT_PHONE=+1-555-0100
# NEXT_PUBLIC_ORG_CONTACT_URL=https://smashwraps.com/about
# NEXT_PUBLIC_ORG_CONTACT_TYPE=customer support

# Resend — transactional + marketing-style flows (welcome, cart reminder, post-purchase).
# Verify your domain in Resend, then set:
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Smash Wraps <orders@yourdomain.com>
# Without these, subscribe/cart/remind APIs still succeed but skip sending (dev-friendly).

# Resend webhook (delivery events) — Dashboard → Webhooks → URL `/api/webhooks/resend`
# RESEND_WEBHOOK_SECRET=whsec_...

# Optional: error tracking (not wired by default)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# --- Marketing automation (optional) — Neon Postgres + Inngest drips (1h / 24h / 72h), segments, A/B ---
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# After setting URL: npm run db:push
#
# Inngest — create app at https://app.inngest.com → Event key + Signing key; sync URL = https://<your-domain>/api/inngest
# INNGEST_EVENT_KEY=...
# INNGEST_SIGNING_KEY=signkey-...
# Local dev: npx inngest-cli@latest dev (proxies to your Next dev server)
#
# HMAC for one-click unsubscribe links in drip emails (generate a long random string)
# EMAIL_UNSUBSCRIBE_SECRET=
# Optional: rotate A/B assignment without code changes
# EMAIL_AB_SALT=smashwraps-welcome-v1
